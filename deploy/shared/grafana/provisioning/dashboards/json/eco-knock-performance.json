{
  "uid": "eco-knock-performance",
  "title": "Eco Knock Performance",
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP request rate",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count[5m]))", "legendFormat": "requests/s" }],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "HTTP p95 latency",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "p95" }],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 }
    },
    {
      "id": 3,
      "title": "HTTP 5xx ratio",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count[5m]))", "legendFormat": "5xx ratio" }],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }
    },
    {
      "id": 4,
      "title": "JVM heap used",
      "type": "timeseries",
      "targets": [{ "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "heap" }],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }
    },
    {
      "id": 5,
      "title": "Process CPU",
      "type": "timeseries",
      "targets": [{ "expr": "process_cpu_usage", "legendFormat": "CPU" }],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 }
    },
    {
      "id": 6,
      "title": "Hikari active connections",
      "type": "timeseries",
      "targets": [{ "expr": "hikaricp_connections_active", "legendFormat": "active" }],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 }
    },
    {
      "id": 7,
      "title": "gRPC client duration p95",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, client, operation) (rate(eco_knock_grpc_client_seconds_bucket[5m])))", "legendFormat": "{{client}} {{operation}}" }],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "id": 8,
      "title": "Polling and queue failures",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (queue) (rate(eco_knock_queue_processing_seconds_count{outcome=\"failure\"}[5m]))", "legendFormat": "queue {{queue}}" },
        { "expr": "sum by (client) (rate(eco_knock_grpc_client_seconds_count{outcome=\"failure\"}[5m]))", "legendFormat": "grpc {{client}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    },
    {
      "id": 9,
      "title": "Auto control actions",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (decision, outcome) (rate(eco_knock_auto_control_action_seconds_count[5m]))", "legendFormat": "{{decision}} {{outcome}}" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 }
    },
    {
      "id": 10,
      "title": "Materialized view refresh duration",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (view, outcome) (rate(eco_knock_materialized_view_refresh_seconds_sum[5m])) / sum by (view, outcome) (rate(eco_knock_materialized_view_refresh_seconds_count[5m]))", "legendFormat": "{{view}} {{outcome}}" }],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 }
    }
  ]
}
